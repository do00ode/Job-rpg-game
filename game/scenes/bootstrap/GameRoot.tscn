[gd_scene load_steps=2 format=3]

; Link the authored scene to its C# composition-root script by a Godot resource path.
[ext_resource type="Script" path="res://src/Rpg.Game/Bootstrap/GameRoot.cs" id="1_game_root"]

; The root remains a plain composition Node. It instantiates the current exploration child
; only after content, session, and save services have been initialized successfully.
[node name="GameRoot" type="Node"]
script = ExtResource("1_game_root")
